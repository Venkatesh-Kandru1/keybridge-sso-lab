{
  "name": "keybridge-sso-lab",
  "version": "2.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently --kill-others --names remote,host --prefix-colors magenta,cyan \"npm:dev:remote\" \"npm:dev:host\"",
    "dev:remote": "webpack serve --config webpack.remote.config.mjs --mode development",
    "dev:host": "wait-on http-get://localhost:3001/remoteEntry.js && webpack serve --config webpack.host.config.mjs --mode development",
    "build": "npm run typecheck && npm run build:remote && npm run build:host",
    "build:remote": "webpack --config webpack.remote.config.mjs --mode production",
    "build:host": "webpack --config webpack.host.config.mjs --mode production",
    "preview": "webpack serve --config webpack.host.config.mjs --mode production",
    "test": "npm run build && node --test tests/*.test.mjs",
    "lint": "eslint src webpack.*.mjs eslint.config.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "concurrently": "10.0.3",
    "copy-webpack-plugin": "14.0.0",
    "css-loader": "7.1.4",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "html-webpack-plugin": "5.6.7",
    "style-loader": "4.0.0",
    "ts-loader": "9.6.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "wait-on": "9.0.10",
    "webpack": "5.108.4",
    "webpack-cli": "7.2.1",
    "webpack-dev-server": "6.0.0"
  },
  "type": "module"
}
